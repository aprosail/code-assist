{
  "name": "code-assist",
  "displayName": "Code Assist",
  "description": "Local auto complete, git line info, and themes.",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/aprosail/code-assist.git",
    "directory": "code-assist"
  },
  "engines": {
    "vscode": "^1.97.2"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "hello",
        "title": "hello.title"
      }
    ]
  },
  "scripts": {
    "build": "vite-node build.ts",
    "package": "vite-node build.ts pack"
  },
  "devDependencies": {
    "@types/vscode": "^1.97.0",
    "@vscode/vsce": "^3.2.2"
  }
}
